{
  "name": "quolt",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Quolt — a modern wrapper for Quill.js.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "dev": "pnpm -r --filter=./packages/* run dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "play": "pnpm --filter @quolt/playground dev",
    "docs:dev": "pnpm --filter @quolt/docs dev",
    "docs:build": "pnpm --filter @quolt/docs build",
    "clean": "pnpm -r exec rimraf dist node_modules/.cache"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "happy-dom": "^15.11.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
